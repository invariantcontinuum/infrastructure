{
  "Servers": {
    "${SERVER_ID}": {
      "Name": "${SERVER_NAME}",
      "Group": "${SERVER_GROUP}",
      "Host": "${SERVER_HOST}",
      "Port": ${SERVER_PORT},
      "MaintenanceDB": "${MAINTENANCE_DB}",
      "Username": "${USERNAME}",
      "SSLMode": "${SSL_MODE}",
      "PassFile": "${PASS_FILE}",
      "SSLCert": "${SSL_CERT}",
      "SSLKey": "${SSL_KEY}",
      "SSLRootCert": "${SSL_ROOT_CERT}",
