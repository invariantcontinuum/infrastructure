      "TunnelUsername": "${TUNNEL_USERNAME}",
      "TunnelAuthentication": ${TUNNEL_AUTH},
      "KerberosAuthentication": ${KERBEROS_AUTH},
      "ConnectionTimeout": ${CONNECTION_TIMEOUT},
