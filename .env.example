# =============================================================================
# INFRASTRUCTURE - CONSOLIDATED ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy: cp .env.example .env then fill secrets
# This file contains all environment variables for all infrastructure services.
# =============================================================================

# =============================================================================
# GLOBAL / SHARED SETTINGS
# =============================================================================

DOMAIN=localhost
TRAEFIK_NETWORK=traefik-public
COMPOSE_PROJECT_NAME=infrastructure

# =============================================================================
# POSTGRESQL - RELATIONAL DATABASE
# =============================================================================

POSTGRES_VERSION=16-alpine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=./services/postgres/data
EXTRA_DATABASES=
POSTGRES_HOST=postgres.localhost

# =============================================================================
# PGADMIN - POSTGRESQL ADMINISTRATION
# =============================================================================

PGADMIN_VERSION=latest
PGADMIN_DEFAULT_EMAIL=admin@localhost.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN
PGADMIN_PORT=5050
PGADMIN_HOST=pgadmin.localhost

# =============================================================================
# KEYCLOAK DATABASE (used by postgres init)
# =============================================================================

KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=CHANGE_ME_KEYCLOAK_DB

# =============================================================================
# NGINX PROXY MANAGER DATABASE
# =============================================================================

NPM_DB_NAME=npm
NPM_DB_USER=npm
NPM_DB_PASSWORD=CHANGE_ME_NPM_DB

# =============================================================================
# N8N DATABASE
# =============================================================================

N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=CHANGE_ME_N8N_DB

# =============================================================================
# REDIS - IN-MEMORY DATA STORE
# =============================================================================

REDIS_VERSION=7-alpine
REDIS_PASSWORD=CHANGE_ME_REDIS
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb
REDIS_ENABLE_AOF=true

# =============================================================================
# REDIS COMMANDER - REDIS WEB UI
# =============================================================================

REDIS_COMMANDER_VERSION=latest
REDIS_COMMANDER_PORT=8081
REDIS_COMMANDER_HOST=redis.localhost

# =============================================================================
# ELASTICSEARCH - SEARCH & ANALYTICS
# =============================================================================

ELASTICSEARCH_VERSION=8.13.0
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_DATA_DIR=./services/elasticsearch/data
ELASTICSEARCH_HEAP_SIZE=1g
ELASTICSEARCH_PASSWORD=CHANGE_ME_ELASTIC
ELASTICSEARCH_SECURITY_ENABLED=false
ELASTICSEARCH_DISCOVERY_TYPE=single-node
ES_CREATE_INDICES=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_HOST=elasticsearch.localhost

# =============================================================================
# KIBANA - DATA VISUALIZATION
# =============================================================================

KIBANA_VERSION=8.13.0
KIBANA_PORT=5601
KIBANA_ELASTICSEARCH_HOSTS=http://elasticsearch:9200
KIBANA_IMPORT_OBJECTS=
KIBANA_HOST=kibana.localhost

# =============================================================================
# KEYCLOAK - IDENTITY & ACCESS MANAGEMENT
# =============================================================================

KEYCLOAK_VERSION=latest
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK
KEYCLOAK_PORT=8080
KEYCLOAK_FEATURES=token-exchange,admin-fine-grained-authz
KEYCLOAK_DEFAULT_THEME=keycloak
KEYCLOAK_WELCOME_THEME=keycloak
KEYCLOAK_LOG_LEVEL=INFO
KEYCLOAK_IMPORT_REALM=
KEYCLOAK_THEME_DIR=./services/keycloak/themes
KEYCLOAK_HOST=keycloak.localhost

# =============================================================================
# NATS - MESSAGE QUEUE & STREAMING
# =============================================================================

NATS_VERSION=2-alpine
NATS_CLIENT_PORT=4222
NATS_HTTP_PORT=8222
NATS_CLUSTER_PORT=6222
NATS_DATA_DIR=./services/nats/data
NATS_JS_MAX_MEMORY=1GB
NATS_JS_MAX_FILE=10GB
NATS_HOST=nats.localhost

# =============================================================================
# NEO4J - GRAPH DATABASE
# =============================================================================

NEO4J_VERSION=5-community
NEO4J_AUTH=neo4j/CHANGE_ME_NEO4J
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_DATA_DIR=./services/neo4j/data
NEO4J_LOGS_DIR=./services/neo4j/logs
NEO4J_PLUGINS_DIR=./services/neo4j/plugins
NEO4J_apoc_export_file_enabled=true
NEO4J_apoc_import_file_enabled=true
NEO4J_apoc_import_file_use__neo4j__config=true
NEO4J_PLUGINS=["apoc"]
NEO4J_LOG_LEVEL=INFO
NEO4J_CONSTRAINTS=
NEO4J_BROWSER_HOST=neo4j-browser.localhost

# =============================================================================
# QDRANT - VECTOR DATABASE
# =============================================================================

QDRANT_VERSION=latest
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_DATA_DIR=./services/qdrant/data
QDRANT_API_KEY=
QDRANT_HOST=qdrant.localhost

# =============================================================================
# NGINX PROXY MANAGER - REVERSE PROXY & SSL
# =============================================================================

NPM_VERSION=latest
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81
NPM_ADMIN_EMAIL=admin@localhost.com
NPM_ADMIN_PASSWORD=CHANGE_ME_ADMIN
